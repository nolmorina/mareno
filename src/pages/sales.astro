---
import { getAuthUser } from '../lib/auth';

const user = getAuthUser(Astro.request);
if (!user) return Astro.redirect('/login');

const currentUser = user.username;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Mareno — Sales</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Jost:wght@200;300;400;500;600&display=swap" rel="stylesheet" />
</head>
<style is:global>
  :root {
    --ch:     #1A1A1A;
    --iv:     #F3F1EC;
    --sand:   #DCCEB8;
    --olive:  #6B705F;
    --taupe:  #A69B90;
    --accent: #B08060;
    --serif:  'Cormorant Garamond', Georgia, serif;
    --sans:   'Jost', Helvetica, sans-serif;
    --bg:     #EDEAE4;
    --card:   #FAFAF8;
    --border: #D8D4CC;
    --gold:   #9A7A30;
    --good:   #3A6A3A;
    --danger: #A93226;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { font-size: 14px; }
  body { font-family: var(--sans); background: var(--bg); color: var(--ch); min-height: 100vh; }
  a { color: inherit; text-decoration: none; }
  button { font-family: inherit; cursor: pointer; }

  /* ── HEADER ─────────────────────────────────────────────────── */
  .sl-hd {
    position: sticky; top: 0; z-index: 200;
    background: var(--ch); color: var(--iv);
    height: 56px; display: flex; align-items: center;
    justify-content: space-between; padding: 0 40px;
  }
  .sl-logo {
    font-family: var(--serif); font-size: 20px; letter-spacing: 0.2em;
    display: flex; align-items: baseline; gap: 12px;
  }
  .sl-logo span {
    font-family: var(--sans); font-size: 8px;
    letter-spacing: 0.24em; text-transform: uppercase; opacity: 0.3; font-weight: 300;
  }
  .sl-hd-right { display: flex; align-items: center; gap: 12px; }
  .sl-user-chip {
    font-size: 8px; letter-spacing: 0.14em; text-transform: uppercase;
    color: rgba(243,241,236,.35); background: rgba(255,255,255,.06);
    padding: 6px 12px; border: 1px solid rgba(255,255,255,.08);
  }
  .sl-hd-link {
    font-size: 8px; letter-spacing: 0.18em; text-transform: uppercase;
    color: rgba(243,241,236,.4); transition: color .2s; padding: 8px 0;
  }
  .sl-hd-link:hover { color: var(--iv); }
  .sl-btn-logout {
    font-size: 8px; letter-spacing: 0.2em; text-transform: uppercase; font-weight: 400;
    background: none; color: rgba(243,241,236,.4); border: 1px solid rgba(255,255,255,.12);
    padding: 9px 16px; transition: all .2s;
  }
  .sl-btn-logout:hover { border-color: rgba(255,255,255,.4); color: var(--iv); }

  /* ── MAIN ────────────────────────────────────────────────────── */
  .sl-main { max-width: 1120px; margin: 0 auto; padding: 36px 28px 100px; }

  /* ── PAGE HEADING ────────────────────────────────────────────── */
  .sl-heading-row {
    display: flex; align-items: flex-end; justify-content: space-between;
    margin-bottom: 28px; flex-wrap: wrap; gap: 16px;
  }
  .sl-heading {
    font-family: var(--serif); font-size: 36px; font-weight: 400;
    letter-spacing: 0.04em; line-height: 1;
  }
  .sl-heading-sub {
    font-size: 9px; letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--taupe); margin-top: 6px;
  }

  /* ── PERIOD CONTROLS ─────────────────────────────────────────── */
  .sl-period-row { display: flex; gap: 6px; align-items: center; flex-wrap: wrap; }
  .sl-period-btn {
    font-size: 8px; letter-spacing: 0.18em; text-transform: uppercase;
    background: none; border: 1px solid var(--border); color: var(--taupe);
    padding: 8px 16px; transition: all .15s;
  }
  .sl-period-btn:hover { border-color: var(--ch); color: var(--ch); }
  .sl-period-btn.active { background: var(--ch); color: var(--iv); border-color: var(--ch); }
  .sl-period-divider { width: 1px; height: 18px; background: var(--border); margin: 0 2px; }

  /* ── LOADING / EMPTY ─────────────────────────────────────────── */
  .sl-loading {
    text-align: center; padding: 80px 28px;
    font-size: 9px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--taupe);
  }
  .sl-empty {
    background: var(--card); border: 1px solid var(--border);
    text-align: center; padding: 64px 28px;
    font-size: 11px; font-weight: 300; color: var(--taupe); line-height: 2;
  }

  /* ── KPI CARDS ───────────────────────────────────────────────── */
  .sl-kpi-row {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 12px;
  }
  .sl-kpi-row-2 {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; margin-bottom: 28px;
  }
  .sl-kpi {
    background: var(--card); border: 1px solid var(--border); padding: 20px 22px;
    display: flex; flex-direction: column; gap: 8px;
  }
  .sl-kpi-label {
    font-size: 7px; letter-spacing: 0.26em; text-transform: uppercase; color: var(--taupe);
  }
  .sl-kpi-value {
    font-family: var(--serif); font-size: 36px; font-weight: 400; line-height: 1; color: var(--ch);
  }
  .sl-kpi-value.gold   { color: var(--gold); }
  .sl-kpi-value.medium { font-size: 20px; letter-spacing: 0.02em; }
  .sl-kpi-sub {
    font-size: 9px; color: var(--taupe); font-weight: 300; margin-top: 2px;
  }

  /* ── SECTION CARD ────────────────────────────────────────────── */
  .sl-card {
    background: var(--card); border: 1px solid var(--border); margin-bottom: 20px;
  }
  .sl-card-head {
    display: flex; align-items: center; justify-content: space-between;
    padding: 14px 20px; border-bottom: 1px solid var(--border);
  }
  .sl-card-title {
    font-size: 7px; letter-spacing: 0.26em; text-transform: uppercase; color: var(--taupe);
  }
  .sl-card-body { padding: 20px; }

  /* ── CHART TOGGLE ────────────────────────────────────────────── */
  .sl-toggle { display: flex; gap: 0; }
  .sl-toggle-btn {
    font-size: 7px; letter-spacing: 0.18em; text-transform: uppercase;
    background: none; border: 1px solid var(--border); color: var(--taupe);
    padding: 6px 14px; transition: all .15s; margin-left: -1px;
  }
  .sl-toggle-btn:first-child { margin-left: 0; }
  .sl-toggle-btn.active { background: var(--ch); color: var(--iv); border-color: var(--ch); z-index: 1; position: relative; }

  /* ── BAR CHART ───────────────────────────────────────────────── */
  .sl-chart-wrap { display: flex; flex-direction: column; gap: 0; padding: 0 4px; }
  .sl-chart-bars {
    display: flex; align-items: flex-end; gap: 6px;
    height: 200px; padding-bottom: 0; position: relative;
  }
  .sl-chart-bars::before {
    content: ''; position: absolute; inset: 0;
    background: repeating-linear-gradient(
      to bottom, transparent 0px, transparent calc(25% - 1px),
      #EDEBE7 calc(25% - 1px), #EDEBE7 25%
    );
    pointer-events: none; z-index: 0;
  }
  .sl-bar-col {
    flex: 1; display: flex; flex-direction: column;
    align-items: center; justify-content: flex-end;
    position: relative; z-index: 1; height: 100%; cursor: default;
  }
  .sl-bar-fill {
    width: 100%; max-width: 52px; background: var(--ch); height: 0;
    transition: height .7s cubic-bezier(.16,1,.3,1); position: relative;
  }
  .sl-bar-fill:hover { background: var(--accent); }
  .sl-bar-fill::after {
    content: attr(data-tip);
    position: absolute; bottom: calc(100% + 6px); left: 50%; transform: translateX(-50%);
    background: var(--ch); color: var(--iv);
    font-size: 9px; letter-spacing: 0.06em; padding: 4px 8px;
    white-space: nowrap; pointer-events: none; opacity: 0; transition: opacity .15s;
  }
  .sl-bar-fill:hover::after { opacity: 1; }
  .sl-bar-lbl {
    font-size: 8px; color: var(--taupe); letter-spacing: 0.04em;
    margin-top: 8px; white-space: nowrap; overflow: hidden;
    text-overflow: ellipsis; max-width: 100%; text-align: center;
  }

  /* ── TWO-COL GRID ────────────────────────────────────────────── */
  .sl-two-col { display: grid; grid-template-columns: 1fr 340px; gap: 20px; margin-bottom: 20px; }

  /* ── PRODUCT TABLE ───────────────────────────────────────────── */
  .sl-prod-table { width: 100%; border-collapse: collapse; font-size: 11px; }
  .sl-prod-table th {
    text-align: left; font-size: 7px; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--taupe); font-weight: 500; padding: 10px 12px;
    border-bottom: 1px solid var(--border); background: #F5F4F0; white-space: nowrap;
  }
  .sl-prod-table th.r { text-align: right; }
  .sl-prod-table td { padding: 10px 12px; border-bottom: 1px solid #EDEBE7; vertical-align: middle; }
  .sl-prod-table tr:last-child td { border-bottom: none; }
  .sl-prod-table tr:hover td { background: #F9F8F6; }
  .sl-prod-img { width: 44px; height: 44px; object-fit: cover; object-position: center top; display: block; }
  .sl-prod-img-empty {
    width: 44px; height: 44px; background: #E8E4DC;
    display: flex; align-items: center; justify-content: center; font-size: 16px; color: var(--border);
  }
  .sl-prod-name-cell .name { font-weight: 400; font-size: 12px; }
  .sl-prod-name-cell .cat  { font-size: 9px; color: var(--taupe); margin-top: 2px; letter-spacing: 0.06em; }
  .sl-prod-name-cell .top-sz { font-size: 8px; color: var(--olive); margin-top: 3px; letter-spacing: 0.06em; }
  .sl-num { text-align: right; font-family: var(--serif); font-size: 14px; }
  .sl-revenue-num { color: var(--gold); }
  .sl-rank { font-size: 9px; color: var(--taupe); width: 24px; text-align: right; }

  /* ── HORIZONTAL BARS ─────────────────────────────────────────── */
  .sl-hbar-list { display: flex; flex-direction: column; gap: 10px; }
  .sl-hbar-row { display: flex; align-items: center; gap: 10px; }
  .sl-hbar-label {
    font-size: 10px; font-weight: 400; min-width: 40px; color: var(--ch);
    letter-spacing: 0.04em; text-align: right; flex-shrink: 0;
  }
  .sl-hbar-label.cat { min-width: 90px; text-align: right; font-size: 9px; letter-spacing: 0.06em; color: var(--taupe); text-transform: uppercase; }
  .sl-hbar-track { flex: 1; height: 6px; background: #EDEBE7; overflow: hidden; }
  .sl-hbar-fill { height: 100%; background: var(--ch); width: 0; transition: width .8s cubic-bezier(.16,1,.3,1); }
  .sl-hbar-val { font-size: 10px; color: var(--ch); white-space: nowrap; min-width: 60px; font-family: var(--serif); }
  .sl-hbar-pct { font-size: 8px; color: var(--taupe); margin-left: 4px; }

  /* ── ALL SALES TABLE ─────────────────────────────────────────── */
  .sl-sales-table { width: 100%; border-collapse: collapse; font-size: 11px; }
  .sl-sales-table th {
    text-align: left; font-size: 7px; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--taupe); font-weight: 500; padding: 10px 14px;
    border-bottom: 1px solid var(--border); background: #F5F4F0; white-space: nowrap;
  }
  .sl-sales-table td {
    padding: 9px 14px; border-bottom: 1px solid #EDEBE7; vertical-align: middle;
  }
  .sl-sales-table tr:last-child td { border-bottom: none; }
  .sl-sales-table tr:hover td { background: #F9F8F6; }
  .sl-time { white-space: nowrap; color: var(--taupe); font-size: 10px; }
  .sl-sz-badge {
    font-size: 8px; font-weight: 500; letter-spacing: 0.08em;
    background: #F0EDE8; padding: 2px 7px; display: inline-block;
  }
  .sl-note-cell { color: rgba(26,26,26,.45); font-weight: 300; max-width: 180px; }
  .sl-admin-cell { color: var(--accent); font-weight: 500; }
  .sl-tbl-empty {
    text-align: center; padding: 40px; font-size: 11px;
    color: var(--taupe); font-weight: 300;
  }

  /* ── FILTERS ─────────────────────────────────────────────────── */
  .sl-filters {
    display: flex; flex-wrap: wrap; gap: 10px; align-items: flex-end;
    padding: 16px 20px; border-bottom: 1px solid var(--border); background: #F5F4F0;
  }
  .sl-fgroup { display: flex; flex-direction: column; gap: 5px; }
  .sl-fgroup label { font-size: 7px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--taupe); }
  .sl-fi {
    font-family: var(--sans); font-size: 11px; background: var(--card);
    border: 1px solid var(--border); padding: 7px 10px; color: var(--ch);
    outline: none; transition: border-color .15s;
  }
  .sl-fi:focus { border-color: var(--ch); }
  .sl-fi-sm { width: 90px; }
  .sl-fi-md { width: 160px; }
  .sl-fi-dt { width: 170px; }
  .sl-btn-filter {
    font-family: var(--sans); font-size: 8px; letter-spacing: 0.18em; text-transform: uppercase;
    background: var(--ch); color: var(--iv); border: 1px solid var(--ch);
    padding: 9px 18px; transition: all .15s; align-self: flex-end;
  }
  .sl-btn-filter:hover { background: #333; border-color: #333; }
  .sl-btn-clear {
    font-family: var(--sans); font-size: 8px; letter-spacing: 0.18em; text-transform: uppercase;
    background: none; color: var(--taupe); border: 1px solid var(--border);
    padding: 9px 14px; transition: all .15s; align-self: flex-end;
  }
  .sl-btn-clear:hover { border-color: var(--ch); color: var(--ch); }

  /* ── PAGINATION ──────────────────────────────────────────────── */
  .sl-paging {
    display: flex; align-items: center; justify-content: space-between;
    padding: 12px 20px; border-top: 1px solid var(--border);
    font-size: 10px; color: var(--taupe);
  }
  .sl-paging-btns { display: flex; gap: 4px; }
  .sl-paging-btn {
    font-family: var(--sans); font-size: 9px; letter-spacing: 0.1em;
    background: none; border: 1px solid var(--border); color: var(--taupe);
    padding: 5px 11px; transition: all .15s;
  }
  .sl-paging-btn:hover:not(:disabled) { border-color: var(--ch); color: var(--ch); }
  .sl-paging-btn:disabled { opacity: .3; cursor: default; }
  .sl-paging-btn.cur { background: var(--ch); color: var(--iv); border-color: var(--ch); }

  /* ── ACTION BUTTONS ──────────────────────────────────────────── */
  .sl-act-btn {
    font-family: var(--sans); font-size: 8px; letter-spacing: 0.14em; text-transform: uppercase;
    padding: 3px 8px; border: 1px solid var(--border); background: transparent;
    color: var(--taupe); cursor: pointer; border-radius: 2px; transition: all .15s;
  }
  .sl-act-btn:hover { border-color: var(--accent); color: var(--accent); }
  .sl-act-del:hover { border-color: #c0392b; color: #c0392b; }

  /* ── EDIT MODAL ──────────────────────────────────────────────── */
  .sl-modal-overlay {
    position: fixed; inset: 0; z-index: 920;
    background: rgba(26,26,26,.52); backdrop-filter: blur(2px);
    display: flex; align-items: center; justify-content: center;
    opacity: 0; pointer-events: none; transition: opacity .2s;
  }
  .sl-modal-overlay.open { opacity: 1; pointer-events: all; }
  .sl-modal-panel {
    background: var(--card); border: 1px solid var(--border);
    width: 460px; max-width: 95vw;
    transform: translateY(16px); transition: transform .28s cubic-bezier(.16,1,.3,1);
  }
  .sl-modal-overlay.open .sl-modal-panel { transform: translateY(0); }
  .sl-modal-header {
    padding: 22px 26px 16px; border-bottom: 1px solid var(--border);
    display: flex; align-items: baseline; justify-content: space-between;
  }
  .sl-modal-heading {
    font-family: var(--serif); font-size: 22px; font-weight: 400; letter-spacing: 0.04em;
  }
  .sl-modal-close {
    background: none; border: none; font-size: 20px; color: var(--taupe); line-height: 1;
    padding: 0; transition: color .15s;
  }
  .sl-modal-close:hover { color: var(--ch); }
  .sl-modal-body { padding: 22px 26px; display: flex; flex-direction: column; gap: 16px; }
  .sl-modal-meta {
    font-size: 10px; color: var(--taupe); background: #F5F4F0;
    border: 1px solid var(--border); padding: 10px 14px; line-height: 1.8;
  }
  .sl-modal-field { display: flex; flex-direction: column; gap: 6px; }
  .sl-modal-label { font-size: 7px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--taupe); }
  .sl-modal-err {
    font-size: 10px; color: var(--danger); display: none; margin-top: 4px;
  }
  .sl-modal-err.show { display: block; }
  .sl-modal-footer {
    padding: 14px 26px; border-top: 1px solid var(--border);
    display: flex; justify-content: flex-end; gap: 10px;
  }
  .sl-btn-cancel {
    font-family: var(--sans); font-size: 8px; letter-spacing: 0.2em; text-transform: uppercase;
    background: none; border: 1px solid var(--border); color: var(--taupe); padding: 10px 20px; transition: all .15s;
  }
  .sl-btn-cancel:hover { border-color: var(--ch); color: var(--ch); }
  .sl-btn-submit {
    font-family: var(--sans); font-size: 8px; letter-spacing: 0.2em; text-transform: uppercase;
    background: var(--ch); color: var(--iv); border: 1px solid var(--ch); padding: 10px 24px; transition: all .15s;
  }
  .sl-btn-submit:hover { background: #333; border-color: #333; }
  .sl-btn-submit:disabled { opacity: .5; cursor: default; }

  /* ── TOAST ───────────────────────────────────────────────────── */
  .sl-toast {
    position: fixed; bottom: 28px; right: 28px;
    background: var(--ch); color: var(--iv);
    font-size: 8px; letter-spacing: 0.2em; text-transform: uppercase;
    padding: 13px 22px; z-index: 999;
    opacity: 0; transform: translateY(16px);
    transition: all .3s cubic-bezier(.16,1,.3,1); pointer-events: none;
  }
  .sl-toast.show { opacity: 1; transform: translateY(0); }

  /* ── RESPONSIVE ──────────────────────────────────────────────── */
  @media (max-width: 900px) {
    .sl-hd { padding: 0 18px; }
    .sl-kpi-row { grid-template-columns: repeat(2, 1fr); }
    .sl-two-col { grid-template-columns: 1fr; }
  }
  @media (max-width: 600px) {
    .sl-kpi-row   { grid-template-columns: 1fr 1fr; }
    .sl-kpi-row-2 { grid-template-columns: 1fr; }
    .sl-filters   { flex-direction: column; align-items: stretch; }
  }
</style>

<body>

<header class="sl-hd">
  <div class="sl-logo">Mareno <span>Sales</span></div>
  <div class="sl-hd-right">
    <span class="sl-user-chip">{currentUser}</span>
    <a href="/admin" class="sl-hd-link">← Admin</a>
    <a href="/"      class="sl-hd-link">Store ↗</a>
    <button class="sl-btn-logout" onclick="doLogout()">Log Out</button>
  </div>
</header>

<main class="sl-main">

  <!-- Heading + period controls -->
  <div class="sl-heading-row">
    <div>
      <h1 class="sl-heading">Sales</h1>
      <div class="sl-heading-sub" id="sl-period-label">Loading…</div>
    </div>
    <div class="sl-period-row" id="sl-period-row">
      <!-- rendered by JS -->
    </div>
  </div>

  <!-- Analytics (KPIs + chart + breakdown) -->
  <div id="sl-content">
    <div class="sl-loading">Loading sales data…</div>
  </div>

  <!-- All Sales Table (separate, always visible after first load) -->
  <div id="sl-table-section" style="display:none">
    <div class="sl-card">
      <div class="sl-card-head">
        <span class="sl-card-title">All Sales</span>
        <span id="sl-tbl-count" style="font-size:9px;color:var(--taupe)"></span>
      </div>

      <!-- Filters -->
      <div class="sl-filters">
        <div class="sl-fgroup">
          <label>Product</label>
          <input class="sl-fi sl-fi-md" id="slf-product" type="text" placeholder="Search product…" />
        </div>
        <div class="sl-fgroup">
          <label>Size</label>
          <input class="sl-fi sl-fi-sm" id="slf-size" type="text" placeholder="e.g. M" />
        </div>
        <div class="sl-fgroup">
          <label>Admin</label>
          <input class="sl-fi sl-fi-sm" id="slf-admin" type="text" placeholder="Username" />
        </div>
        <div class="sl-fgroup">
          <label>From</label>
          <input class="sl-fi sl-fi-dt" id="slf-from" type="datetime-local" />
        </div>
        <div class="sl-fgroup">
          <label>To</label>
          <input class="sl-fi sl-fi-dt" id="slf-to" type="datetime-local" />
        </div>
        <button class="sl-btn-filter" onclick="loadSalesTable(1)">Filter</button>
        <button class="sl-btn-clear"  onclick="clearSalesFilters()">Clear</button>
      </div>

      <!-- Table -->
      <div style="overflow-x:auto">
        <table class="sl-sales-table">
          <thead>
            <tr>
              <th>Time</th>
              <th>Product</th>
              <th>Size</th>
              <th style="text-align:center">Qty</th>
              <th style="text-align:right">Est. Revenue</th>
              <th>Admin</th>
              <th>Note</th>
              <th></th>
            </tr>
          </thead>
          <tbody id="sl-tbl-body">
            <tr><td colspan="8" class="sl-tbl-empty">Loading…</td></tr>
          </tbody>
        </table>
      </div>

      <!-- Pagination -->
      <div class="sl-paging" id="sl-tbl-paging" style="display:none">
        <span id="sl-paging-info"></span>
        <div class="sl-paging-btns" id="sl-paging-btns"></div>
      </div>
    </div>
  </div>

</main>

<!-- ══ EDIT SALE MODAL ══════════════════════════════════════════ -->
<div class="sl-modal-overlay" id="sl-edit-overlay" onclick="editOverlayClick(event)">
  <div class="sl-modal-panel">
    <div class="sl-modal-header">
      <div class="sl-modal-heading">Edit Sale</div>
      <button class="sl-modal-close" onclick="closeEditModal()">×</button>
    </div>
    <div class="sl-modal-body">
      <input type="hidden" id="sl-edit-id" />
      <div class="sl-modal-meta" id="sl-edit-meta"></div>
      <div class="sl-modal-field">
        <label class="sl-modal-label">Qty Sold</label>
        <input class="sl-fi" id="sl-edit-qty" type="number" min="1" style="width:110px" />
      </div>
      <div class="sl-modal-field">
        <label class="sl-modal-label">Note</label>
        <input class="sl-fi" id="sl-edit-note" type="text" maxlength="300" placeholder="Optional…" style="width:100%" />
      </div>
      <div class="sl-modal-err" id="sl-edit-err"></div>
    </div>
    <div class="sl-modal-footer">
      <button class="sl-btn-cancel" onclick="closeEditModal()">Cancel</button>
      <button class="sl-btn-submit" id="sl-edit-submit" onclick="submitEditSale()">Save Changes</button>
    </div>
  </div>
</div>

<div class="sl-toast" id="sl-toast"></div>

<script is:inline>
/* ── STATE ───────────────────────────────────────────────────── */
let salesData    = null;
let activePeriod = null;
let chartMetric  = 'units';
let salesTblPage = 1;
let salesPriceMap = {};   // productId → price, populated from analytics data

/* ── HELPERS ─────────────────────────────────────────────────── */
function esc(s) {
  return String(s ?? '')
    .replace(/&/g,'&amp;').replace(/"/g,'&quot;')
    .replace(/</g,'&lt;').replace(/>/g,'&gt;');
}
function fmtUnits(n)   { return Number(n).toLocaleString(); }
function fmtRevenue(n) { return '€' + Math.round(n).toLocaleString('de-DE'); }
function fmtAvg(n)     { return '€' + Math.round(n).toLocaleString('de-DE'); }

function showToast(msg) {
  const t = document.getElementById('sl-toast');
  t.textContent = msg; t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2600);
}

async function apiFetch(url, opts = {}) {
  const res  = await fetch(url, opts);
  const data = await res.json().catch(() => ({}));
  if (!res.ok) throw new Error(data.error ?? `HTTP ${res.status}`);
  return data;
}

/* ── COUNT-UP ANIMATION ──────────────────────────────────────── */
function countUp(el, target, fmt) {
  const dur = 900;
  const start = performance.now();
  const tick = now => {
    const p = Math.min((now - start) / dur, 1);
    el.textContent = fmt(Math.round(target * (1 - Math.pow(1 - p, 3))));
    if (p < 1) requestAnimationFrame(tick);
  };
  requestAnimationFrame(tick);
}

/* ── LOGOUT ──────────────────────────────────────────────────── */
async function doLogout() {
  try { await fetch('/api/auth/logout', { method: 'POST' }); } catch {}
  window.location.href = '/login';
}

/* ── FETCH ANALYTICS ─────────────────────────────────────────── */
async function loadSales(period) {
  activePeriod = period;
  renderPeriodControls();

  const content = document.getElementById('sl-content');
  content.innerHTML = '<div class="sl-loading">Loading…</div>';

  const qs = period && period !== 'all' ? `?year=${period}` : '';
  try {
    const res  = await fetch('/api/sales' + qs);
    const data = await res.json();
    if (!res.ok) throw new Error(data.error ?? `HTTP ${res.status}`);
    salesData = data;

    // Build price map for revenue estimates in the table
    salesPriceMap = {};
    (salesData.byProduct ?? []).forEach(p => {
      salesPriceMap[p.productId] = p.price;
    });

    renderAll();
    document.getElementById('sl-table-section').style.display = '';
    loadSalesTable(1);
  } catch (err) {
    content.innerHTML = `<div class="sl-empty">Failed to load: ${esc(err.message)}</div>`;
  }
}

/* ── PERIOD CONTROLS ─────────────────────────────────────────── */
function renderPeriodControls() {
  const years = salesData?.availableYears ?? [];
  const currentYear = new Date().getFullYear();

  if (!years.length && !salesData) {
    document.getElementById('sl-period-row').innerHTML =
      `<button class="sl-period-btn active" onclick="loadSales('all')">All Time</button>`;
    return;
  }

  const allYears = [...new Set([...years, currentYear])].sort((a,b) => b - a);
  document.getElementById('sl-period-row').innerHTML =
    `<button class="sl-period-btn${activePeriod === 'all' ? ' active' : ''}" onclick="loadSales('all')">All Time</button>
     <div class="sl-period-divider"></div>` +
    allYears.map(y =>
      `<button class="sl-period-btn${activePeriod === String(y) ? ' active' : ''}" onclick="loadSales('${y}')">${y}</button>`
    ).join('');

  document.getElementById('sl-period-label').textContent =
    activePeriod === 'all' ? 'All time' : `January – December ${activePeriod}`;
}

/* ── RENDER ANALYTICS ────────────────────────────────────────── */
function renderAll() {
  if (!salesData) return;
  renderPeriodControls();
  const { summary, monthly, byProduct, bySize, byCategory } = salesData;

  document.getElementById('sl-content').innerHTML = `
    ${kpiHTML(summary)}
    ${chartCardHTML()}
    <div class="sl-two-col">
      ${topProductsCardHTML(byProduct)}
      <div>${sizeCatCardHTML(bySize, byCategory)}</div>
    </div>
  `;

  animateKPIs(summary);
  drawChart(monthly, chartMetric);
  setTimeout(() => animateBars(), 60);
}

/* ── KPI CARDS ───────────────────────────────────────────────── */
function kpiHTML(s) {
  return `
  <div class="sl-kpi-row">
    <div class="sl-kpi"><div class="sl-kpi-label">Units Sold</div><div class="sl-kpi-value" id="kpi-units">—</div></div>
    <div class="sl-kpi">
      <div class="sl-kpi-label">Est. Revenue</div>
      <div class="sl-kpi-value gold" id="kpi-revenue">—</div>
      <div class="sl-kpi-sub">based on current prices</div>
    </div>
    <div class="sl-kpi"><div class="sl-kpi-label">Transactions</div><div class="sl-kpi-value" id="kpi-transactions">—</div></div>
    <div class="sl-kpi"><div class="sl-kpi-label">Avg per Sale</div><div class="sl-kpi-value gold" id="kpi-avg">—</div></div>
  </div>
  <div class="sl-kpi-row-2">
    <div class="sl-kpi">
      <div class="sl-kpi-label">Best Selling Product</div>
      <div class="sl-kpi-value medium">${esc(s.bestSelling)}</div>
    </div>
    <div class="sl-kpi">
      <div class="sl-kpi-label">Top Size</div>
      <div class="sl-kpi-value medium">${esc(s.topSize)}${s.topSizePct > 0 ? `<span style="font-size:16px;color:var(--taupe);margin-left:10px">${s.topSizePct}% of sales</span>` : ''}</div>
    </div>
  </div>`;
}
function animateKPIs(s) {
  const u = document.getElementById('kpi-units');
  const r = document.getElementById('kpi-revenue');
  const t = document.getElementById('kpi-transactions');
  const a = document.getElementById('kpi-avg');
  if (u) countUp(u, s.totalUnits,        v => fmtUnits(v));
  if (r) countUp(r, s.totalRevenue,      v => fmtRevenue(v));
  if (t) countUp(t, s.totalTransactions, v => fmtUnits(v));
  if (a) countUp(a, s.avgOrderValue,     v => fmtAvg(v));
}

/* ── CHART ───────────────────────────────────────────────────── */
function chartCardHTML() {
  return `
  <div class="sl-card" style="margin-bottom:20px">
    <div class="sl-card-head">
      <span class="sl-card-title">Monthly Sales</span>
      <div class="sl-toggle">
        <button class="sl-toggle-btn${chartMetric==='units'?   ' active':''}" onclick="switchMetric('units')">Units</button>
        <button class="sl-toggle-btn${chartMetric==='revenue'?' active':''}" onclick="switchMetric('revenue')">Revenue</button>
      </div>
    </div>
    <div class="sl-card-body">
      <div class="sl-chart-wrap" id="sl-chart-wrap"></div>
    </div>
  </div>`;
}
function drawChart(monthly, metric) {
  const wrap = document.getElementById('sl-chart-wrap');
  if (!wrap) return;
  if (!monthly.length) {
    wrap.innerHTML = '<p style="text-align:center;padding:32px;font-size:11px;color:var(--taupe)">No data for this period.</p>';
    return;
  }
  const vals = monthly.map(m => metric === 'revenue' ? m.revenue : m.units);
  const max  = Math.max(...vals, 1);
  const bars = monthly.map(m => {
    const val = metric === 'revenue' ? m.revenue : m.units;
    const h   = Math.round((val / max) * 200);
    const tip = metric === 'revenue' ? `${m.label}: ${fmtRevenue(val)}` : `${m.label}: ${fmtUnits(val)} units`;
    return `<div class="sl-bar-col">
      <div class="sl-bar-fill" data-h="${h}" data-tip="${esc(tip)}" style="height:0"></div>
      <div class="sl-bar-lbl">${esc(m.label.split(' ')[0])}</div>
    </div>`;
  }).join('');
  wrap.innerHTML = `<div class="sl-chart-bars">${bars}</div>`;
  requestAnimationFrame(() => requestAnimationFrame(() => {
    wrap.querySelectorAll('.sl-bar-fill').forEach(el => { el.style.height = el.dataset.h + 'px'; });
  }));
}
function switchMetric(m) {
  chartMetric = m;
  document.querySelectorAll('.sl-toggle-btn').forEach(b => {
    b.classList.toggle('active', b.textContent.toLowerCase() === m);
  });
  if (salesData) drawChart(salesData.monthly, m);
}

/* ── TOP PRODUCTS ────────────────────────────────────────────── */
function topProductsCardHTML(byProduct) {
  if (!byProduct.length) return `<div class="sl-card"><div class="sl-card-head"><span class="sl-card-title">Top Products</span></div>
    <div class="sl-empty" style="border:none">No sales recorded yet.</div></div>`;
  const rows = byProduct.map((p, i) => {
    const topSzEntry = Object.entries(p.bySizeUnits).sort((a,b) => b[1]-a[1])[0];
    const topSz = topSzEntry ? `Top size: ${topSzEntry[0]} (${topSzEntry[1]})` : '';
    const img = p.img
      ? `<img class="sl-prod-img" src="${esc(p.img)}" alt="${esc(p.productName)}" />`
      : `<div class="sl-prod-img-empty">&#9634;</div>`;
    return `<tr>
      <td class="sl-rank">${i+1}</td>
      <td style="padding:8px 12px">${img}</td>
      <td class="sl-prod-name-cell">
        <div class="name">${esc(p.productName)}</div>
        <div class="cat">${esc(p.cat)}</div>
        ${topSz ? `<div class="top-sz">${esc(topSz)}</div>` : ''}
      </td>
      <td class="sl-num">${fmtUnits(p.units)}</td>
      <td class="sl-num sl-revenue-num">${fmtRevenue(p.revenue)}</td>
    </tr>`;
  }).join('');
  return `<div class="sl-card">
    <div class="sl-card-head"><span class="sl-card-title">Top Products</span></div>
    <div style="overflow-x:auto">
      <table class="sl-prod-table">
        <thead><tr>
          <th style="width:24px">#</th><th style="width:52px"></th>
          <th>Product</th><th class="r">Units</th><th class="r">Est. Revenue</th>
        </tr></thead>
        <tbody>${rows}</tbody>
      </table>
    </div>
  </div>`;
}

/* ── SIZE + CATEGORY ─────────────────────────────────────────── */
function sizeCatCardHTML(bySize, byCategory) {
  const sizeRows = bySize.slice(0,8).map(s => `
    <div class="sl-hbar-row">
      <div class="sl-hbar-label">${esc(s.size)}</div>
      <div class="sl-hbar-track"><div class="sl-hbar-fill" data-pct="${s.pct}"></div></div>
      <div class="sl-hbar-val">${fmtUnits(s.units)}<span class="sl-hbar-pct">${s.pct}%</span></div>
    </div>`).join('') || '<p style="font-size:11px;color:var(--taupe);padding:8px 0">No data.</p>';
  const catRows = byCategory.slice(0,6).map(c => `
    <div class="sl-hbar-row">
      <div class="sl-hbar-label cat">${esc(c.cat)}</div>
      <div class="sl-hbar-track"><div class="sl-hbar-fill" data-pct="${c.pct}"></div></div>
      <div class="sl-hbar-val">${fmtUnits(c.units)}<span class="sl-hbar-pct">${c.pct}%</span></div>
    </div>`).join('') || '<p style="font-size:11px;color:var(--taupe);padding:8px 0">No data.</p>';
  return `
  <div class="sl-card" style="margin-bottom:20px">
    <div class="sl-card-head"><span class="sl-card-title">By Size</span></div>
    <div class="sl-card-body"><div class="sl-hbar-list">${sizeRows}</div></div>
  </div>
  <div class="sl-card">
    <div class="sl-card-head"><span class="sl-card-title">By Category</span></div>
    <div class="sl-card-body"><div class="sl-hbar-list">${catRows}</div></div>
  </div>`;
}
function animateBars() {
  document.querySelectorAll('.sl-hbar-fill[data-pct]').forEach(el => { el.style.width = el.dataset.pct + '%'; });
}

/* ── ALL SALES TABLE ─────────────────────────────────────────── */
async function loadSalesTable(page) {
  salesTblPage = page ?? 1;
  const tbody  = document.getElementById('sl-tbl-body');
  if (tbody) tbody.innerHTML = `<tr><td colspan="8" class="sl-tbl-empty">Loading…</td></tr>`;

  const params = new URLSearchParams();
  params.set('reason', 'sale');
  params.set('page',   salesTblPage);
  params.set('limit',  '25');

  const product = document.getElementById('slf-product')?.value.trim();
  const size    = document.getElementById('slf-size')?.value.trim();
  const admin   = document.getElementById('slf-admin')?.value.trim();
  const from    = document.getElementById('slf-from')?.value;
  const to      = document.getElementById('slf-to')?.value;

  if (product) params.set('product', product);
  if (size)    params.set('size',    size);
  if (admin)   params.set('admin',   admin);
  if (from)    params.set('from',    new Date(from).toISOString());
  if (to)      params.set('to',      new Date(to).toISOString());

  // Also scope to the active period year if not 'all'
  if (activePeriod && activePeriod !== 'all') {
    const y = parseInt(activePeriod);
    if (!from) params.set('from', new Date(`${y}-01-01T00:00:00.000Z`).toISOString());
    if (!to)   params.set('to',   new Date(`${y+1}-01-01T00:00:00.000Z`).toISOString());
  }

  try {
    const { logs, total, limit } = await apiFetch('/api/inventory/logs?' + params.toString());

    document.getElementById('sl-tbl-count').textContent = `${total} entries`;

    if (!logs.length) {
      tbody.innerHTML = `<tr><td colspan="8" class="sl-tbl-empty">No sales found.</td></tr>`;
      document.getElementById('sl-tbl-paging').style.display = 'none';
      return;
    }

    tbody.innerHTML = logs.map(l => {
      const d   = new Date(l.createdAt);
      const t   = d.toLocaleDateString() + ' ' + d.toLocaleTimeString([], { hour:'2-digit', minute:'2-digit' });
      const qty = Math.abs(l.delta);
      const price   = salesPriceMap[l.productId] ?? 0;
      const revenue = qty * price;
      return `<tr>
        <td class="sl-time">${esc(t)}</td>
        <td style="font-weight:400">${esc(l.productName)}</td>
        <td><span class="sl-sz-badge">${esc(l.size)}</span></td>
        <td style="text-align:center;font-family:var(--serif);font-size:13px">${qty}</td>
        <td style="text-align:right;font-family:var(--serif);font-size:13px;color:var(--gold)">${fmtRevenue(revenue)}</td>
        <td class="sl-admin-cell">${esc(l.adminUser)}</td>
        <td class="sl-note-cell">${esc(l.note || '—')}</td>
        <td>
          <div style="display:flex;gap:4px">
            <button class="sl-act-btn" onclick="openEditModal(${esc(JSON.stringify(String(l._id)))},${qty},${esc(JSON.stringify(l.note||''))},${esc(JSON.stringify(l.productName))},${esc(JSON.stringify(l.size))})">Edit</button>
            <button class="sl-act-btn sl-act-del" onclick="deleteSale(${esc(JSON.stringify(String(l._id)))},${esc(JSON.stringify(l.productName))},${esc(JSON.stringify(l.size))})">Del</button>
          </div>
        </td>
      </tr>`;
    }).join('');

    renderSalesTablePaging(total, limit);
  } catch (err) {
    if (tbody) tbody.innerHTML = `<tr><td colspan="8" class="sl-tbl-empty">Error: ${esc(err.message)}</td></tr>`;
  }
}

function renderSalesTablePaging(total, limit) {
  const pages  = Math.ceil(total / limit) || 1;
  const paging = document.getElementById('sl-tbl-paging');
  const info   = document.getElementById('sl-paging-info');
  const btns   = document.getElementById('sl-paging-btns');
  if (!paging) return;

  paging.style.display = '';
  if (info) info.textContent = `Page ${salesTblPage} of ${pages} · ${total} entries`;
  if (!btns) return;

  // Show prev, up to 5 page numbers, next
  const maxBtns = 5;
  let start = Math.max(1, salesTblPage - Math.floor(maxBtns / 2));
  let end   = Math.min(pages, start + maxBtns - 1);
  if (end - start < maxBtns - 1) start = Math.max(1, end - maxBtns + 1);

  let html = `<button class="sl-paging-btn" onclick="loadSalesTable(${salesTblPage - 1})" ${salesTblPage <= 1 ? 'disabled' : ''}>‹ Prev</button>`;
  for (let p = start; p <= end; p++) {
    html += `<button class="sl-paging-btn${p === salesTblPage ? ' cur' : ''}" onclick="loadSalesTable(${p})">${p}</button>`;
  }
  html += `<button class="sl-paging-btn" onclick="loadSalesTable(${salesTblPage + 1})" ${salesTblPage >= pages ? 'disabled' : ''}>Next ›</button>`;
  btns.innerHTML = html;
}

function clearSalesFilters() {
  ['slf-product','slf-size','slf-admin','slf-from','slf-to'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.value = '';
  });
  loadSalesTable(1);
}

/* ── EDIT SALE MODAL ─────────────────────────────────────────── */
function openEditModal(id, qty, note, productName, size) {
  document.getElementById('sl-edit-id').value   = id;
  document.getElementById('sl-edit-qty').value  = qty;
  document.getElementById('sl-edit-note').value = note;
  document.getElementById('sl-edit-meta').innerHTML =
    `<strong>${esc(productName)}</strong> &nbsp;·&nbsp; Size: <strong>${esc(size)}</strong>`;
  const errEl = document.getElementById('sl-edit-err');
  if (errEl) { errEl.textContent = ''; errEl.classList.remove('show'); }
  document.getElementById('sl-edit-overlay').classList.add('open');
}

function closeEditModal() {
  document.getElementById('sl-edit-overlay').classList.remove('open');
}

function editOverlayClick(e) {
  if (e.target === document.getElementById('sl-edit-overlay')) closeEditModal();
}

async function submitEditSale() {
  const id   = document.getElementById('sl-edit-id').value;
  const qty  = Math.max(1, parseInt(document.getElementById('sl-edit-qty').value) || 1);
  const note = document.getElementById('sl-edit-note').value.trim();
  const errEl = document.getElementById('sl-edit-err');
  const btn   = document.getElementById('sl-edit-submit');
  btn.disabled = true; btn.textContent = 'Saving…';
  try {
    await apiFetch('/api/inventory/sale', {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id, qty, note }),
    });
    closeEditModal();
    showToast('Sale updated');
    loadSalesTable(salesTblPage);
    loadSales(activePeriod);
  } catch (err) {
    if (errEl) { errEl.textContent = 'Error: ' + err.message; errEl.classList.add('show'); }
  } finally {
    btn.disabled = false; btn.textContent = 'Save Changes';
  }
}

async function deleteSale(id, productName, size) {
  if (!confirm(`Delete this sale entry for "${productName}" (${size})?\nStock will be restored.`)) return;
  try {
    await apiFetch('/api/inventory/sale', {
      method: 'DELETE',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id }),
    });
    showToast('Sale deleted — stock restored');
    loadSalesTable(salesTblPage);
    loadSales(activePeriod);
  } catch (err) {
    alert('Error: ' + err.message);
  }
}

/* ── INIT ────────────────────────────────────────────────────── */
const thisYear = String(new Date().getFullYear());
document.getElementById('sl-period-row').innerHTML =
  `<button class="sl-period-btn" onclick="loadSales('all')">All Time</button>
   <div class="sl-period-divider"></div>
   <button class="sl-period-btn active" onclick="loadSales('${thisYear}')">${thisYear}</button>`;

document.addEventListener('keydown', e => {
  if (e.key === 'Escape') closeEditModal();
});

loadSales(thisYear);
</script>

</body>
</html>
