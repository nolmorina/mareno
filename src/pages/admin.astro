/* ── ACTIVITY LOG ──────────────────────────────────────────────── */
let logPage = 1;

async function loadLogs(page) {
  logPage = page ?? 1;
  const u = document.getElementById('log-f-user')?.value.trim()   ?? '';
  const a = document.getElementById('log-f-action')?.value.trim() ?? '';
  const f = document.getElementById('log-f-from')?.value          ?? '';
  const t = document.getElementById('log-f-to')?.value            ?? '';

  const params = new URLSearchParams({ page: logPage, limit: 20 });
  if (u) params.set('username', u);
  if (a) params.set('action', a);
  if (f) params.set('from', new Date(f).toISOString());
  if (t) params.set('to',   new Date(t).toISOString());

  const tbody = document.getElementById('log-tbody');
  tbody.innerHTML = '<tr><td colspan="4" class="adm-log-empty">Loading…</td></tr>';

  try {
    const { logs, total, limit } = await apiFetch('/api/logs?' + params.toString());
    if (!logs.length) {
      tbody.innerHTML = '<tr><td colspan="4" class="adm-log-empty">No log entries found.</td></tr>';
    } else {
      tbody.innerHTML = logs.map(l => `
        <tr>
          <td class="adm-log-time">${new Date(l.createdAt).toLocaleString()}</td>
          <td class="adm-log-user">${esc(l.username)}</td>
          <td class="adm-log-action">${esc(l.action)}</td>
          <td class="adm-log-detail">${esc(l.detail)}</td>
        </tr>`).join('');
    }
    renderLogPaging(total, limit);
  } catch (err) {
    tbody.innerHTML = `<tr><td colspan="4" class="adm-log-empty">Error: ${esc(err.message)}</td></tr>`;
  }
}

function renderLogPaging(total, limit) {
  const pages = Math.ceil(total / limit) || 1;
  const paging = document.getElementById('log-paging');
  if (pages <= 1) { paging.innerHTML = `<span class="pg-info">${total} entries</span>`; return; }
  paging.innerHTML =
    `<button onclick="loadLogs(${logPage - 1})" ${logPage <= 1 ? 'disabled' : ''}>‹</button>
     <span class="pg-info">Page ${logPage} / ${pages} &nbsp;·&nbsp; ${total} entries</span>
     <button onclick="loadLogs(${logPage + 1})" ${logPage >= pages ? 'disabled' : ''}>›</button>`;
}

function clearLogFilters() {
  ['log-f-user','log-f-action','log-f-from','log-f-to'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.value = '';
  });
  loadLogs(1);
}

load();

