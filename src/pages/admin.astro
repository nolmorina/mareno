<script is:inline>
/* ── STATE ─────────────────────────────────────────────────────── */
let products = [];
let hero     = { img: '' };
let editorial = { img: '' };
let uploadTargetId = null;

const CATEGORY_OPTIONS = ['Shirts','Short-Sleeve','Trousers','Shorts','Knitwear','Jackets','Accessories'];
const CATEGORY_TAGS = {
  'Shirts': 'shirts',
  'Short-Sleeve': 'shortsleeve',
  'Trousers': 'trousers',
  'Shorts': 'shorts',
  'Knitwear': 'knitwear',
  'Jackets': 'jackets',
  'Accessories': 'accessories',
};
const CATEGORY_TAG_VALUES = new Set(Object.values(CATEGORY_TAGS));

function categoryTag(cat) {
  return CATEGORY_TAGS[cat] ?? String(cat ?? '').toLowerCase().replace(/[^a-z]/g, '');
}

function categoryOptionsHTML(selected, includeNone = false) {
  return `${includeNone ? '<option value="">None</option>' : ''}${CATEGORY_OPTIONS.map(c =>
    `<option value="${c}"${selected === c ? ' selected' : ''}>${c}</option>`
  ).join('')}`;
}

function secondaryCategory(p) {
  const primaryTag = categoryTag(p.cat);
  const tags = String(p.cats ?? '').split(/\s+/).filter(Boolean);
  const secondaryTag = tags.find(tag => CATEGORY_TAG_VALUES.has(tag) && tag !== primaryTag);
  return CATEGORY_OPTIONS.find(cat => categoryTag(cat) === secondaryTag) ?? '';
}

function extraFilterTags(p) {
  return String(p.cats ?? '')
    .split(/\s+/)
    .filter(tag => tag && !CATEGORY_TAG_VALUES.has(tag))
    .join(' ');
}

function composeFilterTags(primary, secondary, extras = '') {
  const tags = [categoryTag(primary), secondary ? categoryTag(secondary) : ''];
  tags.push(...String(extras).split(/\s+/).filter(Boolean));
  return [...new Set(tags.filter(Boolean))].join(' ');
}

function normalizePrice(value) {
  const price = String(value ?? '').trim();
  if (!price) return '';
  if (price.startsWith('€')) return price;
  return price.replace(/^[£$]/, '€').replace(/^(?!€)/, '€');
}

/* ── API HELPERS ───────────────────────────────────────────────── */
async function apiFetch(url, opts = {}) {
  const res = await fetch(url, opts);
  const data = await res.json().catch(() => ({}));
  if (!res.ok) throw new Error(data.error ?? `HTTP ${res.status}`);
  return data;
}

/* ── LOAD FROM API ─────────────────────────────────────────────── */
async function load() {
  try {
    const [prods, settings] = await Promise.all([
      apiFetch('/api/products'),
      apiFetch('/api/settings'),
    ]);
    products  = Array.isArray(prods) ? prods : [];
    hero      = settings.hero      ?? { img: '' };
    editorial = settings.editorial ?? { img: '' };
    renderHero();
    renderEditorial();
    render();
    loadLogs(1);
  } catch (err) {
    showToast('Failed to load data: ' + err.message);
    console.error(err);
  }
}

function setZoneImg(zoneId, previewId, url) {
  const zone = document.getElementById(zoneId);
  const img  = document.getElementById(previewId);
  if (url) {
    img.style.display = '';
    img.src = url;
    zone.classList.add('has-img');
  } else {
    img.src = '';
    img.style.display = 'none';
    zone.classList.remove('has-img');
  }
}

function renderHero() {
  document.getElementById('hero-img').value = hero.img ?? '';
  setZoneImg('hero-zone', 'hero-preview', hero.img);
}

function collectHero() {
  const img = document.getElementById('hero-img').value.trim();
  if (img) hero.img = img;
}

function renderEditorial() {
  document.getElementById('editorial-img').value = editorial.img ?? '';
  setZoneImg('editorial-zone', 'editorial-preview', editorial.img);
}

function collectEditorial() {
  const img = document.getElementById('editorial-img').value.trim();
  if (img) editorial.img = img;
}

async function saveHero() {
  collectHero();
  try {
    await apiFetch('/api/settings', {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ key: 'hero', value: hero }),
    });
    const btn = document.getElementById('btn-save-hero');
    btn.textContent = 'Saved ✓'; btn.classList.add('ok');
    showToast('Hero image saved');
    setTimeout(() => { btn.textContent = 'Save'; btn.classList.remove('ok'); }, 2000);
  } catch (err) { showToast('Error: ' + err.message); }
}

async function saveEditorial() {
  collectEditorial();
  try {
    await apiFetch('/api/settings', {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ key: 'editorial', value: editorial }),
    });
    const btn = document.getElementById('btn-save-editorial');
    btn.textContent = 'Saved ✓'; btn.classList.add('ok');
    showToast('Editorial image saved');
    setTimeout(() => { btn.textContent = 'Save'; btn.classList.remove('ok'); }, 2000);
  } catch (err) { showToast('Error: ' + err.message); }
}

/* ── COLLECT FORM VALUES → products[] ─────────────────────────── */
function collect() {
  document.querySelectorAll('.adm-card').forEach(card => {
    const id = parseInt(card.dataset.id);
    const p = products.find(x => x.id === id);
    if (!p) return;

    p.name     = v(card, '.fi-name');
    p.cat      = v(card, '.fi-cat');
    p.price    = normalizePrice(v(card, '.fi-price'));
    p.priceOld = normalizePrice(v(card, '.fi-old'));
    p.badge    = v(card, '.fi-badge');
    p.cats     = composeFilterTags(p.cat, v(card, '.fi-cat-secondary'), v(card, '.fi-cats'));
    p.desc     = card.querySelector('.adm-fta')?.value ?? p.desc;

    p.specs = [];
    card.querySelectorAll('.adm-spec-row').forEach(r => {
      const k = r.querySelector('.adm-spec-k').value.trim();
      const val = r.querySelector('.adm-spec-v').value.trim();
      if (k) p.specs.push([k, val]);
    });

    const sizesStr = card.querySelector('.fi-sizes')?.value ?? '';
    p.sizes = sizesStr.split(',').map(s => s.trim()).filter(Boolean);
    p.avail = [];
    card.querySelectorAll('.adm-sz.in').forEach(b => p.avail.push(b.dataset.size));

    p.images = [];
    card.querySelectorAll('.adm-extra-img-url').forEach(inp => {
      if (inp.value.trim()) p.images.push(inp.value.trim());
    });

    p.colors = [];
    card.querySelectorAll('.adm-color-chip').forEach(ce => {
      p.colors.push({ bg: ce.querySelector('input[type="color"]').value, title: ce.querySelector('.adm-cn').value });
    });
  });
}

function v(card, sel) { return card.querySelector(sel)?.value ?? ''; }

/* ── CONFIRM DIALOG ────────────────────────────────────────────── */
function openDialog({ icon, title, msg, confirmLabel, danger, onConfirm }) {
  document.getElementById('dlg-icon').textContent    = icon ?? '';
  document.getElementById('dlg-title').textContent   = title;
  document.getElementById('dlg-msg').textContent     = msg;
  const btn = document.getElementById('dlg-confirm');
  btn.textContent = confirmLabel ?? 'Confirm';
  btn.className = 'adm-dialog-confirm' + (danger ? ' danger' : '');
  btn.onclick = () => { closeDialog(); onConfirm(); };
  document.getElementById('adm-overlay').classList.add('open');
}
function closeDialog() {
  document.getElementById('adm-overlay').classList.remove('open');
}
function overlayClick(e) {
  if (e.target === document.getElementById('adm-overlay')) closeDialog();
}
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeDialog(); });

/* ── SAVE ALL ──────────────────────────────────────────────────── */
function saveAll() {
  collectHero();
  collectEditorial();
  collect();

  const total   = products.length;
  const visible = products.filter(p => !p.hidden).length;
  const hidden  = total - visible;

  openDialog({
    icon: '💾',
    title: 'Save changes?',
    msg: `Saving to database:<br><br>• HERO IMAGE<br>• EDITORIAL IMAGE<br>• PRODUCTS (${visible} visible, ${hidden} hidden)`,
    confirmLabel: 'Save',
    onConfirm: async () => {
      const btn = document.getElementById('btn-save');
      btn.disabled = true; btn.textContent = 'Saving…';
      try {
        await Promise.all([
          apiFetch('/api/settings', { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ key: 'hero', value: hero }) }),
          apiFetch('/api/settings', { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ key: 'editorial', value: editorial }) }),
          apiFetch('/api/products', { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(products) }),
        ]);
        // Flush any pending inventory from newly created products
        const pendingEntries = Object.entries(npStockPending);
        if (pendingEntries.length) {
          await Promise.all(pendingEntries.map(([id, stock]) =>
            apiFetch('/api/inventory', {
              method: 'PUT',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ productId: parseInt(id), stock, note: 'Set at product creation' }),
            })
          ));
          npStockPending = {};
        }
        btn.textContent = 'Saved ✓'; btn.classList.add('ok');
        showToast('All changes saved to database');
        loadLogs(1);
        setTimeout(() => { btn.textContent = 'Save Changes'; btn.classList.remove('ok'); btn.disabled = false; }, 2600);
      } catch (err) {
        showToast('Save failed: ' + err.message);
        btn.textContent = 'Save Changes'; btn.disabled = false;
      }
    }
  });
}

/* ── RENDER ────────────────────────────────────────────────────── */
function render() {
  const sorted = [...products].sort((a, b) => a.order - b.order);
  document.getElementById('prod-list').innerHTML =
    sorted.map((p, i) => cardHTML(p, i, sorted.length)).join('');
  document.getElementById('prod-count').textContent = `Products (${products.length})`;
}

function cardHTML(p, i, total) {
  const specRows = (p.specs || []).map(([k, val]) => `
    <div class="adm-spec-row">
      <input class="adm-fi adm-spec-k" value="${esc(k)}" placeholder="e.g. Fabric" />
      <input class="adm-fi adm-spec-v" value="${esc(val)}" placeholder="e.g. 100% Linen" />
      <button class="adm-rm-btn" onclick="removeSpec(this)">×</button>
    </div>`).join('');

  const sizeBtns = (p.sizes || []).map(s => {
    const cls = (p.avail || []).includes(s) ? 'in' : 'out';
    return `<button class="adm-sz ${cls}" data-size="${s}" onclick="toggleSize(this)">${s}</button>`;
  }).join('');

  const colorChips = (p.colors || []).map(c => `
    <div class="adm-color-chip">
      <input type="color" value="${esc(c.bg)}" />
      <input class="adm-cn" value="${esc(c.title)}" placeholder="Name" />
      <button class="adm-rm-c" onclick="removeColor(this)">×</button>
    </div>`).join('');

  const hidCls  = p.hidden ? 'is-hidden' : '';
  const visLbl  = p.hidden ? 'Hidden' : 'Visible';
