function esc(s) {
  return String(s ?? '').replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

/* ── TOGGLE DETAIL ─────────────────────────────────────────────── */
function toggleDetail(btn) {
  const panel = btn.closest('.adm-card').querySelector('.adm-detail');
  const open = panel.classList.toggle('open');
  btn.textContent = open ? 'Details ▴' : 'Details ▾';
  btn.classList.toggle('open', open);
}

/* ── VISIBILITY / DELETE ───────────────────────────────────────── */
function toggleVisible(id) {
  collect();
  const p = products.find(x => x.id === id);
  if (p) p.hidden = !p.hidden;
  render();
}

function deleteProduct(id) {
  const p = products.find(x => x.id === id);
  openDialog({
    icon: '🗑',
    title: `Delete "${p?.name ?? 'this product'}"?`,
    msg: 'This will permanently remove the product from the store. This cannot be undone.',
    confirmLabel: 'Delete',
    danger: true,
    onConfirm: () => {
      collect();
      products = products.filter(x => x.id !== id);
      reorder(); render();
      showToast('Product deleted');
    }
  });
}

/* ── ORDER ─────────────────────────────────────────────────────── */
function reorder() {
  products.sort((a, b) => a.order - b.order).forEach((p, i) => p.order = i);
}

function moveUp(id) {
  collect();
  const s = [...products].sort((a, b) => a.order - b.order);
  const i = s.findIndex(x => x.id === id);
  if (i < 1) return;
  [s[i].order, s[i-1].order] = [s[i-1].order, s[i].order];
  reorder(); render();
}

function moveDown(id) {
  collect();
  const s = [...products].sort((a, b) => a.order - b.order);
  const i = s.findIndex(x => x.id === id);
  if (i >= s.length - 1) return;
  [s[i].order, s[i+1].order] = [s[i+1].order, s[i].order];
  reorder(); render();
}

/* ── ADD PRODUCT PANEL ─────────────────────────────────────────── */
let npImg          = ''; // stores URL of main product image
let npStockPending = {}; // { productId: [{size, qty}] } — flushed on saveAll

function addProduct() {
  // reset form
  npImg = '';
  npImages = [];
  document.getElementById('np-name').value  = '';
  document.getElementById('np-price').value = '';
  document.getElementById('np-old').value   = '';
  document.getElementById('np-badge').value = '';
  document.getElementById('np-cat').value   = 'Shirts';
  document.getElementById('np-cat-secondary').value = '';
  const zone = document.getElementById('np-img-zone');
  zone.classList.remove('has-img');
  zone.querySelector('img')?.remove();
  document.getElementById('np-extra-imgs').innerHTML = '';
  document.getElementById('np-sizes').value = 'XS, S, M, L, XL';
  renderNpStockGrid();
  // clear errors
  ['np-err-img','np-err-name','np-err-price'].forEach(id => {
    document.getElementById(id).classList.remove('show');
  });
  ['np-name','np-price'].forEach(id => {
    document.getElementById(id).classList.remove('error');
  });
  document.getElementById('np-overlay').classList.add('open');
}

function closeNewProduct() {
  document.getElementById('np-overlay').classList.remove('open');
}

function renderNpStockGrid() {
  const sizes = (document.getElementById('np-sizes')?.value ?? '')
    .split(',').map(s => s.trim()).filter(Boolean);
  const grid = document.getElementById('np-stock-grid');
  if (!grid) return;
  if (!sizes.length) {
    grid.innerHTML = '<p style="font-size:11px;color:var(--taupe);margin-top:4px">Enter sizes above to set quantities.</p>';
    return;
  }
  // Preserve existing values when list is edited
  const prev = {};
  grid.querySelectorAll('.stk-rsi-input').forEach(inp => { prev[inp.dataset.size] = inp.value; });
  grid.innerHTML = sizes.map(s => `
    <div class="stk-rsi">
      <div class="stk-rsi-label">${esc(s)}</div>
      <input class="stk-rsi-input" type="number" min="0" data-size="${esc(s)}" value="${prev[s] ?? 0}" />
    </div>`).join('');
}

document.getElementById('np-img-file').addEventListener('change', async function () {
  const file = this.files[0];
  if (!file) return;
  this.value = '';
  showToast('Uploading image…');
  try {
    const url = await uploadFile(file);
    npImg = url;
    const zone = document.getElementById('np-img-zone');
    let img = zone.querySelector('img');
    if (!img) { img = document.createElement('img'); zone.appendChild(img); }
    img.src = npImg;
    zone.classList.add('has-img');
    document.getElementById('np-err-img').classList.remove('show');
    showToast('Image uploaded');
  } catch (err) {
    showToast('Upload failed: ' + err.message);
  }
});

function submitNewProduct() {
  const name  = document.getElementById('np-name').value.trim();
  const price = normalizePrice(document.getElementById('np-price').value);
  let valid = true;

  // validate
  if (!npImg) {
    document.getElementById('np-err-img').classList.add('show');
    valid = false;
  }
  if (!name) {
    document.getElementById('np-name').classList.add('error');
    document.getElementById('np-err-name').classList.add('show');
    valid = false;
  } else {
    document.getElementById('np-name').classList.remove('error');
    document.getElementById('np-err-name').classList.remove('show');
  }
  if (!price) {
    document.getElementById('np-price').classList.add('error');
    document.getElementById('np-err-price').classList.add('show');
    valid = false;
  } else {
    document.getElementById('np-price').classList.remove('error');
    document.getElementById('np-err-price').classList.remove('show');
  }
  if (!valid) return;

  const cat       = document.getElementById('np-cat').value;
  const secondCat = document.getElementById('np-cat-secondary').value;
  const old       = normalizePrice(document.getElementById('np-old').value);
  const badge     = document.getElementById('np-badge').value.trim();

  // Read sizes + stock before panel closes
  const npSizesList = (document.getElementById('np-sizes')?.value ?? 'XS, S, M, L, XL')
    .split(',').map(s => s.trim()).filter(Boolean);
  const npStockData = [];
  document.querySelectorAll('#np-stock-grid .stk-rsi-input').forEach(inp => {
    npStockData.push({ size: inp.dataset.size, qty: Math.max(0, parseInt(inp.value) || 0) });
  });

  // all good — confirm
  closeNewProduct();
  openDialog({
    icon: '✓',
    title: `Add "${name}" to the collection?`,
    msg: `${cat}${secondCat ? ' + ' + secondCat : ''} · ${price}${old ? ' · sale ' + old : ''}${badge ? ' · ' + badge : ''}`,
    confirmLabel: 'Add to Collection',
    onConfirm: () => {
      collect();
      const newId  = products.length ? Math.max(...products.map(p => p.id)) + 1 : 0;
      const maxOrd = products.length ? Math.max(...products.map(p => p.order)) + 1 : 0;
      const extraTags = badge.toLowerCase().includes('new') ? 'new' : '';
      const catTag = composeFilterTags(cat, secondCat, extraTags);
      products.push({
        id: newId, order: maxOrd, hidden: true,
        name, cat, cats: catTag,
        price, priceOld: old, badge,
        img: npImg,
        images: [...npImages],
        colors: [{ bg:'#DCCEB8', title:'Sand' }],
        desc: '',
        specs: [['Fabric',''],['Origin','Made in Portugal']],
        sizes: npSizesList.length ? npSizesList : ['XS','S','M','L','XL'],
        avail: npStockData.filter(s => s.qty > 0).map(s => s.size),
      });
      if (npStockData.some(s => s.qty > 0)) {
        npStockPending[newId] = npStockData;
      }
      render();
      showToast('Product added');
      setTimeout(() => {
        const cards = document.querySelectorAll('.adm-card');
        const last  = cards[cards.length - 1];
        last?.scrollIntoView({ behavior: 'smooth', block: 'center' });
        const expBtn = last?.querySelector('.adm-exp-btn');
        if (expBtn) toggleDetail(expBtn);
      }, 80);
    }
  });
}

