let inventory = [];
let stkLogPage = 1;

/* ── TAB SWITCHING ──────────────────────────────────────────────── */
function switchTab(tab) {
  ['products','stock','log'].forEach(t => {
    const panel = document.getElementById('adm-tab-' + t);
    const btn   = document.getElementById('adm-tab-btn-' + t);
    if (panel) panel.style.display = (t === tab) ? '' : 'none';
    if (btn)   btn.classList.toggle('active', t === tab);
  });
  if (tab === 'stock') { loadInventory(); loadStockLogs(1); }
  if (tab === 'log')   loadLogs(1);
}

/* ── LOAD INVENTORY ─────────────────────────────────────────────── */
async function loadInventory() {
  try {
    const data = await apiFetch('/api/inventory');
    inventory = Array.isArray(data) ? data : [];
    renderStockTable();
  } catch (err) {
    showToast('Failed to load inventory: ' + err.message);
  }
}

/* ── KPI CARDS ──────────────────────────────────────────────────── */
function renderStockKPIs() {
  let totalUnits = 0, oosCount = 0, lowCount = 0;

  inventory.forEach(inv => {
    let hasOOS = false, hasLow = false;
    const stockMap = {};
    (inv.stock || []).forEach(l => { stockMap[l.size] = l.qty; });
    (inv.sizes || []).forEach(s => {
      const qty = stockMap[s] ?? 0;
      totalUnits += qty;
      if (qty === 0) hasOOS = true;
      else if (qty <= (inv.lowStockAt ?? 2)) hasLow = true;
    });
    if (hasOOS) oosCount++;
    else if (hasLow) lowCount++;
  });

  const set = (id, val, cls) => {
    const el = document.getElementById(id);
    if (!el) return;
    el.textContent = val;
    el.className   = 'stk-kpi-value' + (cls ? ' ' + cls : '');
  };

  set('stk-kpi-products', inventory.length, '');
  set('stk-kpi-units',    totalUnits, '');
  set('stk-kpi-low',      lowCount, lowCount > 0 ? 'warn' : '');
  set('stk-kpi-oos',      oosCount, oosCount > 0 ? 'danger' : '');

  // Tab badge
  const badge = document.getElementById('adm-tab-badge-stock');
  const alertCount = oosCount + lowCount;
  if (badge) {
    badge.textContent = String(alertCount);
    badge.style.display = alertCount > 0 ? '' : 'none';
  }
}

/* ── ALERT BANNERS ──────────────────────────────────────────────── */
function renderStockAlerts() {
  const wrap = document.getElementById('stk-alerts-wrap');
  if (!wrap) return;

  const oosList = [], lowList = [];

  inventory.forEach(inv => {
    const stockMap = {};
    (inv.stock || []).forEach(l => { stockMap[l.size] = l.qty; });
    (inv.sizes || []).forEach(s => {
      const qty = stockMap[s] ?? 0;
      if (qty === 0) oosList.push(`${inv.productName} — ${s}`);
      else if (qty <= (inv.lowStockAt ?? 2)) lowList.push(`${inv.productName} — ${s}: ${qty} left`);
    });
  });

  let html = '';
  if (oosList.length) {
    const preview = oosList.slice(0, 6).map(s => esc(s)).join(' &middot; ');
    const more    = oosList.length > 6 ? ` <em>+${oosList.length - 6} more</em>` : '';
    html += `<div class="stk-alert danger"><span class="stk-alert-icon">!</span>
      <span><strong>${oosList.length} size${oosList.length > 1 ? 's' : ''} out of stock:</strong> ${preview}${more}</span></div>`;
  }
  if (lowList.length) {
    const preview = lowList.slice(0, 6).map(s => esc(s)).join(' &middot; ');
    const more    = lowList.length > 6 ? ` <em>+${lowList.length - 6} more</em>` : '';
    html += `<div class="stk-alert"><span class="stk-alert-icon">&#9651;</span>
      <span><strong>${lowList.length} size${lowList.length > 1 ? 's' : ''} running low:</strong> ${preview}${more}</span></div>`;
  }
  wrap.innerHTML = html;
}

/* ── RENDER STOCK TABLE ─────────────────────────────────────────── */
function renderStockTable() {
  const label = document.getElementById('stk-label');
  if (label) label.textContent = `Inventory (${inventory.length})`;

  if (!inventory.length) {
    const thead = document.getElementById('stk-thead-row');
    const tbody = document.getElementById('stk-tbody');
    if (thead) thead.innerHTML = '<th style="text-align:center;padding:24px;color:var(--taupe)">No products found</th>';
    if (tbody) tbody.innerHTML = '';
    renderStockKPIs();
    renderStockAlerts();
    return;
  }

  // Collect unique sizes in order of first appearance
  const allSizes = [];
  inventory.forEach(inv => {
    (inv.sizes || []).forEach(s => {
      if (!allSizes.includes(s)) allSizes.push(s);
    });
  });

  const thead = document.getElementById('stk-thead-row');
  if (thead) {
    thead.innerHTML =
      `<th style="width:52px;min-width:52px;padding:0"></th>` +
      `<th style="text-align:left;min-width:180px">Product</th>` +
      allSizes.map(s => `<th style="min-width:58px">${esc(s)}</th>`).join('') +
      `<th style="text-align:left">Actions</th>`;
  }

  const tbody = document.getElementById('stk-tbody');
  if (tbody) {
    tbody.innerHTML = inventory.map(inv => {
      const stockMap = {};
      (inv.stock || []).forEach(l => { stockMap[l.size] = l.qty; });

      const sizeCells = allSizes.map(s => {
        if (!(inv.sizes || []).includes(s)) return `<td class="stk-qty-cell na">—</td>`;
        const qty = stockMap[s] ?? 0;
        const cls = qty === 0 ? 'oos' : qty <= (inv.lowStockAt ?? 2) ? 'low' : 'good';
        const sub = qty === 0 ? 'OOS' : qty <= (inv.lowStockAt ?? 2) ? 'Low' : '';
        return `<td class="stk-qty-cell ${cls}">${qty}${sub ? `<span class="stk-qty-sub">${sub}</span>` : ''}</td>`;
      }).join('');

      const imgCell = inv.img
        ? `<td class="stk-img-cell"><img src="${esc(inv.img)}" alt="${esc(inv.productName)}" /></td>`
        : `<td class="stk-img-cell"><div class="stk-img-empty">&#9634;</div></td>`;

      return `<tr>
        ${imgCell}
        <td class="stk-name-cell">
          <div class="stk-prod-name">${esc(inv.productName)}</div>
          <div class="stk-prod-cat">${esc(inv.cat || '')}</div>
        </td>
        ${sizeCells}
        <td class="stk-actions-cell">
          <button class="stk-btn-restock" onclick="openRestockModal(${inv.productId})">Restock</button>
        </td>
      </tr>`;
    }).join('');
  }

  renderStockKPIs();
  renderStockAlerts();
}

/* ── SALE MODAL ─────────────────────────────────────────────────── */
let saleSelectedProductId = null;
let saleSelectedSize      = null;

function openSaleModal() {
  saleSelectedProductId = null;
  saleSelectedSize      = null;

  const sel = document.getElementById('stk-sale-product');
  if (sel) {
    sel.innerHTML = `<option value="">— Select a product —</option>` +
      inventory.map(inv => `<option value="${inv.productId}">${esc(inv.productName)}</option>`).join('');
    sel.value = '';
  }

  const qtyInp = document.getElementById('stk-sale-qty');
  if (qtyInp) qtyInp.value = 1;
  const noteInp = document.getElementById('stk-sale-note');
  if (noteInp) noteInp.value = '';

  clearSaleErr();
  renderSaleSizes();
  document.getElementById('stk-sale-overlay').classList.add('open');
}

function closeSaleModal() {
  document.getElementById('stk-sale-overlay').classList.remove('open');
}

function saleOverlayClick(e) {
  if (e.target === document.getElementById('stk-sale-overlay')) closeSaleModal();
}

function onSaleProductChange() {
  saleSelectedProductId = parseInt(document.getElementById('stk-sale-product').value) || null;
  saleSelectedSize = null;
  clearSaleErr();
  renderSaleSizes();
}

function renderSaleSizes() {
  const wrap = document.getElementById('stk-sale-sizes');
  if (!wrap) return;

  if (!saleSelectedProductId) {
    wrap.innerHTML = '<p style="font-size:11px;color:var(--taupe)">Select a product first.</p>';
    return;
  }
  const inv = inventory.find(i => i.productId === saleSelectedProductId);
  if (!inv || !(inv.sizes || []).length) {
    wrap.innerHTML = '<p style="font-size:11px;color:var(--taupe)">No sizes defined for this product.</p>';
    return;
  }

  const stockMap = {};
  (inv.stock || []).forEach(l => { stockMap[l.size] = l.qty; });

  wrap.innerHTML = (inv.sizes || []).map(s => {
    const qty     = stockMap[s] ?? 0;
    const oos     = qty === 0;
    const selCls  = saleSelectedSize === s ? ' selected' : '';
    const oosCls  = oos ? ' oos' : '';
    const onclick = oos ? '' : `onclick="pickSaleSize('${esc(s)}',this)"`;
    return `<button class="stk-sz-pick${oosCls}${selCls}" ${onclick} ${oos ? 'disabled' : ''} type="button">
      <span class="sz-lbl">${esc(s)}</span>
      <span class="sz-qty">${oos ? 'OOS' : qty + ' left'}</span>
    </button>`;
  }).join('');
}

function pickSaleSize(s, el) {
  saleSelectedSize = s;
  document.querySelectorAll('#stk-sale-sizes .stk-sz-pick').forEach(b => b.classList.remove('selected'));
  el.classList.add('selected');
}

function stkStepQty(delta) {
  const inp = document.getElementById('stk-sale-qty');
  inp.value = Math.max(1, (parseInt(inp.value) || 1) + delta);
}

function clearSaleErr() {
  const el = document.getElementById('stk-sale-err');
  if (el) { el.textContent = ''; el.classList.remove('show'); }
}

function showSaleErr(msg) {
  const el = document.getElementById('stk-sale-err');
  if (el) { el.textContent = msg; el.classList.add('show'); }
}

async function submitSale() {
  clearSaleErr();
  if (!saleSelectedProductId) { showSaleErr('Please select a product.'); return; }
  if (!saleSelectedSize)      { showSaleErr('Please select a size.'); return; }

  const qty  = Math.max(1, parseInt(document.getElementById('stk-sale-qty').value) || 1);
  const note = document.getElementById('stk-sale-note').value.trim();

  const btn = document.getElementById('stk-sale-submit');
  btn.disabled = true; btn.textContent = 'Recording…';

  try {
    await apiFetch('/api/inventory/sale', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ productId: saleSelectedProductId, size: saleSelectedSize, qty, note }),
    });
    closeSaleModal();
    showToast('Sale recorded');
    loadInventory();
    loadStockLogs(1);
  } catch (err) {
    showSaleErr('Error: ' + err.message);
  } finally {
    btn.disabled = false; btn.textContent = 'Record Sale';
  }
}

/* ── RESTOCK MODAL ──────────────────────────────────────────────── */
let restockProductId = null;

function openRestockModal(productId) {
  restockProductId = productId;
  const inv = inventory.find(i => i.productId === productId);
  if (!inv) return;

  const titleEl = document.getElementById('stk-restock-title');
  if (titleEl) titleEl.textContent = inv.productName;

  const stockMap = {};
  (inv.stock || []).forEach(l => { stockMap[l.size] = l.qty; });

  const grid = document.getElementById('stk-restock-grid');
  if (grid) {
    grid.innerHTML = (inv.sizes || []).map(s => {
      const current = stockMap[s] ?? 0;
      return `<div class="stk-rsi">
        <div class="stk-rsi-label">${esc(s)}</div>
        <input class="stk-rsi-input" type="number" min="0" data-size="${esc(s)}" value="${current}" />
        <div class="stk-rsi-current">was ${current}</div>
      </div>`;
    }).join('');
  }

  const noteInp = document.getElementById('stk-restock-note');
  if (noteInp) noteInp.value = '';
  const errEl = document.getElementById('stk-restock-err');
  if (errEl) { errEl.textContent = ''; errEl.classList.remove('show'); }

  document.getElementById('stk-restock-overlay').classList.add('open');
}

function closeRestockModal() {
  document.getElementById('stk-restock-overlay').classList.remove('open');
}

function restockOverlayClick(e) {
  if (e.target === document.getElementById('stk-restock-overlay')) closeRestockModal();
}

async function submitRestock() {
  const errEl = document.getElementById('stk-restock-err');
  if (errEl) { errEl.textContent = ''; errEl.classList.remove('show'); }

  const stock = [];
  document.querySelectorAll('#stk-restock-grid .stk-rsi-input').forEach(inp => {
    stock.push({ size: inp.dataset.size, qty: Math.max(0, parseInt(inp.value) || 0) });
  });

  const note = document.getElementById('stk-restock-note').value.trim();
  const btn  = document.getElementById('stk-restock-submit');
  btn.disabled = true; btn.textContent = 'Saving…';

  try {
    await apiFetch('/api/inventory', {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ productId: restockProductId, stock, note }),
    });
    closeRestockModal();
    showToast('Stock updated');
    loadInventory();
    loadStockLogs(1);
  } catch (err) {
    if (errEl) { errEl.textContent = 'Error: ' + err.message; errEl.classList.add('show'); }
  } finally {
    btn.disabled = false; btn.textContent = 'Save Stock';
  }
}

/* ── STOCK HISTORY ──────────────────────────────────────────────── */
async function loadStockLogs(page) {
  stkLogPage = page ?? 1;
  const product = document.getElementById('stklog-f-product')?.value.trim() ?? '';
  const reason  = document.getElementById('stklog-f-reason')?.value ?? '';
  const from    = document.getElementById('stklog-f-from')?.value ?? '';
  const to      = document.getElementById('stklog-f-to')?.value ?? '';

  const params = new URLSearchParams({ page: stkLogPage, limit: 20 });
  if (product) params.set('product', product);
  if (reason)  params.set('reason', reason);
  if (from)    params.set('from', new Date(from).toISOString());
  if (to)      params.set('to',   new Date(to).toISOString());

  const tbody = document.getElementById('stk-log-tbody');
  if (tbody) tbody.innerHTML = '<tr><td colspan="8" class="stk-log-empty">Loading…</td></tr>';

  try {
    const { logs, total, limit } = await apiFetch('/api/inventory/logs?' + params.toString());
    if (!logs.length) {
      tbody.innerHTML = '<tr><td colspan="8" class="stk-log-empty">No stock movements found.</td></tr>';
    } else {
      tbody.innerHTML = logs.map(l => {
        const pos = l.delta > 0;
        const deltaStr = (pos ? '+' : '') + l.delta;
        const deltaCls = pos ? 'stk-delta-pos' : 'stk-delta-neg';
        return `<tr>
          <td style="white-space:nowrap;color:var(--taupe);font-size:10px">${new Date(l.createdAt).toLocaleString()}</td>
          <td>${esc(l.productName)}</td>
          <td style="font-weight:500;letter-spacing:0.06em">${esc(l.size)}</td>
          <td class="${deltaCls}">${esc(deltaStr)}</td>
          <td><span class="stk-reason-tag ${esc(l.reason)}">${esc(l.reason)}</span></td>
          <td style="font-family:var(--serif);font-size:13px">${l.qtyAfter}</td>
          <td style="color:var(--accent);font-weight:500">${esc(l.adminUser)}</td>
          <td style="color:rgba(26,26,26,.45);font-weight:300">${esc(l.note || '—')}</td>
        </tr>`;
      }).join('');
    }
    renderStkLogPaging(total, limit);
  } catch (err) {
    if (tbody) tbody.innerHTML = `<tr><td colspan="8" class="stk-log-empty">Error: ${esc(err.message)}</td></tr>`;
  }
}

function renderStkLogPaging(total, limit) {
  const pages  = Math.ceil(total / limit) || 1;
  const paging = document.getElementById('stk-log-paging');
  if (!paging) return;
  if (pages <= 1) {
    paging.innerHTML = `<span style="font-size:10px;color:var(--taupe)">${total} entries</span>`;
    return;
  }
  paging.innerHTML =
    `<button onclick="loadStockLogs(${stkLogPage - 1})" ${stkLogPage <= 1 ? 'disabled' : ''}>‹</button>
     <span style="padding:0 6px;font-size:10px;color:var(--taupe)">Page ${stkLogPage} / ${pages} · ${total} entries</span>
     <button onclick="loadStockLogs(${stkLogPage + 1})" ${stkLogPage >= pages ? 'disabled' : ''}>›</button>`;
}

function clearStkLogFilters() {
  ['stklog-f-product','stklog-f-reason','stklog-f-from','stklog-f-to'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.value = '';
  });
  loadStockLogs(1);
}

// Close stock modals on Escape
document.addEventListener('keydown', e => {
  if (e.key !== 'Escape') return;
  if (document.getElementById('stk-sale-overlay')?.classList.contains('open'))    closeSaleModal();
  if (document.getElementById('stk-restock-overlay')?.classList.contains('open')) closeRestockModal();
});
</script>
</body>
</html>
