---
const values = [
  {
    title: 'Considered Design',
    desc: 'Every silhouette begins with restraint. We remove until only the essential remains.',
    icon: `<svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="rgba(243,241,236,0.45)" stroke-width="1"><circle cx="8" cy="8" r="6.5"/><path d="M8 4.5v3.5l2.5 2.5"/></svg>`,
  },
  {
    title: 'Natural Materials',
    desc: 'Linen, wool, silk. Fabrics grown and harvested with integrity, not industry.',
    icon: `<svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="rgba(243,241,236,0.45)" stroke-width="1"><path d="M8 1.5L14 5l0 6L8 14.5 2 11l0-6z"/></svg>`,
  },
  {
    title: 'Slow Fashion',
    desc: 'Small runs. No overstock. Made to be worn for decades, not discarded each season.',
    icon: `<svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="rgba(243,241,236,0.45)" stroke-width="1"><rect x="2" y="2" width="12" height="12"/><path d="M5 6h6M5 9h6M5 12h3"/></svg>`,
  },
  {
    title: 'Ethical Origin',
    desc: 'Every workshop. Every weaver. Every hand that touches our garments — known and respected.',
    icon: `<svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="rgba(243,241,236,0.45)" stroke-width="1"><path d="M8 1.5Q13.5 4.5 13.5 8.5Q13.5 12.5 8 14.5Q2.5 12.5 2.5 8.5Q2.5 4.5 8 1.5Z"/></svg>`,
  },
];
---
<section class="values" id="about">
  <div class="section-label reveal">
    <span class="sec-num">02</span>
    <span class="sec-title">Our Principles</span>
    <div class="sec-rule"></div>
  </div>
  <div class="values-grid">
    {values.map((v, i) => (
      <div class="value-card reveal" style={`animation-delay:${i * 0.1}s`}>
        <div class="val-icon" set:html={v.icon} />
        <p class="val-title">{v.title}</p>
        <p class="val-desc">{v.desc}</p>
      </div>
    ))}
  </div>
</section>
